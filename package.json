{
  "name": "whoop-mcp",
  "version": "0.1.0",
  "description": "Self-hosted MCP server for your WHOOP data via the official WHOOP v2 OAuth API. Bring your own client id/secret; your tokens stay on your infrastructure.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "whoop-mcp": "dist/bin/stdio.js",
    "whoop-mcp-http": "dist/bin/http.js",
    "whoop-mcp-auth": "dist/bin/auth.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "auth": "tsx src/bin/auth.ts",
    "start:stdio": "tsx src/bin/stdio.ts",
    "start:http": "tsx src/bin/http.ts",
    "dev": "tsx watch src/bin/http.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@upstash/redis": "^1.34.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
