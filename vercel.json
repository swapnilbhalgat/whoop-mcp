{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/mcp", "destination": "/api/index" },
    { "source": "/authorize", "destination": "/api/index" },
    { "source": "/token", "destination": "/api/index" },
    { "source": "/register", "destination": "/api/index" },
    { "source": "/revoke", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/.well-known/:path*", "destination": "/api/index" }
  ]
}
