# ─── WHOOP app (create one at https://developer.whoop.com) ───────────────────
WHOOP_CLIENT_ID=your_client_id
WHOOP_CLIENT_SECRET=your_client_secret
# Must match a redirect URI registered on your WHOOP app exactly.
WHOOP_REDIRECT_URI=http://127.0.0.1:3000/callback
# Space-separated. "offline" is REQUIRED to receive a refresh token.
WHOOP_SCOPES=offline read:recovery read:sleep read:workout read:cycles read:profile read:body_measurement

# ─── Storage backend ─────────────────────────────────────────────────────────
# "file"  -> local / single process (default; zero external deps)
# "redis" -> remote / serverless (recommended for any hosted deploy)
STORAGE=file

# file mode only — defaults to ~/.whoop-mcp/tokens.json
# TOKEN_FILE=/data/whoop-tokens.json

# redis mode — Upstash REST credentials (set STORAGE=redis to use these)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── HTTP transport (remote deploy) ──────────────────────────────────────────
PORT=3000
# Gates Claude -> your server. Generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Paste the SAME value into Claude's custom-connector "API key" field.
MCP_BEARER_KEY=
