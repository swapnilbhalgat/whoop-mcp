# ─── WHOOP app (create one at https://developer.whoop.com) ───────────────────
WHOOP_CLIENT_ID=your_client_id
WHOOP_CLIENT_SECRET=your_client_secret
# Must match a redirect URI registered on your WHOOP app exactly.
WHOOP_REDIRECT_URI=http://127.0.0.1:3000/callback
# Space-separated. "offline" is REQUIRED to receive a refresh token.
WHOOP_SCOPES=offline read:recovery read:sleep read:workout read:cycles read:profile read:body_measurement

# ─── Storage backend ─────────────────────────────────────────────────────────
# "file"  -> local / single process (default; zero external deps)
# "redis" -> remote / serverless (recommended for any hosted deploy)
STORAGE=file

# file mode only — defaults to ~/.whoop-mcp/tokens.json
# TOKEN_FILE=/data/whoop-tokens.json

# redis mode — Upstash REST credentials (set STORAGE=redis to use these)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── HTTP transport (remote deploy) ──────────────────────────────────────────
PORT=3000

# ─── OAuth 2.1 (Claude -> your server) ───────────────────────────────────────
# claude.ai custom connectors authenticate via OAuth, not a static bearer, so
# this server is its own OAuth authorization server. These are required for the
# remote deploy (and it needs STORAGE=redis so tokens live in shared storage).
#
# Public https URL of this deploy = the OAuth issuer (no trailing slash / path).
PUBLIC_BASE_URL=https://your-app.vercel.app
# Single-user login you enter once on the consent page (/authorize). Generate a
# strong value, e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_LOGIN_PASSWORD=
# Optional token lifetimes (seconds): access default 3600, refresh default 60 days.
# OAUTH_ACCESS_TTL=3600
# OAUTH_REFRESH_TTL=5184000
